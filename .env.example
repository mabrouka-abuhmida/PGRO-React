# ============================================
# PGR Matching System - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection URL
# Format: postgresql://username:password@host:port/database_name
# For local development: postgresql://pgr_user:pgr_password@localhost:5432/pgr_db
# For Docker: postgresql://pgr_user:pgr_password@postgres:5432/pgr_db
DATABASE_URL=postgresql://pgr_user:pgr_password@localhost:5432/pgr_db

# Database Connection Pool Settings (optional, defaults shown)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30
DB_CONNECT_TIMEOUT=10

# ============================================
# Redis Configuration
# ============================================
# Redis connection URL
# For local development: redis://localhost:6379/0
# For Docker: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# Enable/disable Redis caching (true/false)
REDIS_ENABLED=true

# ============================================
# OpenAI / LLM Configuration
# ============================================
# Your OpenAI API key (REQUIRED for LLM features)
OPENAI_API_KEY=your_openai_api_key_here

# Embedding model to use
EMBEDDING_MODEL=text-embedding-3-small

# LLM model for completions
LLM_MODEL=gpt-4.1

# LLM temperature (0.0 to 2.0, lower = more deterministic)
LLM_TEMPERATURE=0.2

# ============================================
# SendGrid Email Configuration
# ============================================
# Your SendGrid API key (REQUIRED for email service)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Email sender address
EMAIL_FROM_ADDRESS=noreply@example.com

# Email sender name
EMAIL_FROM_NAME=PGR Matching System

# ============================================
# Service URLs (for inter-service communication)
# ============================================
# For local development, use localhost
# For Docker, use service names (e.g., http://staff-service:8001)
STAFF_SERVICE_URL=http://localhost:8001
APPLICANT_SERVICE_URL=http://localhost:8002
MATCHING_SERVICE_URL=http://localhost:8003
FILE_SERVICE_URL=http://localhost:8004
AUTH_SERVICE_URL=http://localhost:8005
EMAIL_SERVICE_URL=http://localhost:8006

# ============================================
# CORS Configuration
# ============================================
# Allowed origins for CORS (comma-separated)
# For local development: http://localhost:5173
# Can include multiple origins: http://localhost:5173,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173

# ============================================
# File Storage Configuration
# ============================================
# Path for file storage (optional, defaults to ./storage/uploads)
# Leave empty to use default
FILE_STORAGE_PATH=

# ============================================
# Environment
# ============================================
# Environment: development, staging, or production
ENVIRONMENT=development

# ============================================
# Query Profiling (Development/Debugging)
# ============================================
# Enable query profiling middleware
QUERY_PROFILING_ENABLED=true

# Log queries slower than this threshold (seconds)
QUERY_PROFILING_LOG_THRESHOLD=0.1

# Flag N+1 queries if same query executed this many times
QUERY_PROFILING_N_PLUS_ONE_THRESHOLD=5

# ============================================
# Docker-specific Notes
# ============================================
# When running with Docker Compose:
# - Use service names for DATABASE_URL host: postgres
# - Use service names for REDIS_URL host: redis
# - Use service names for service URLs: http://staff-service:8001
# - POSTGRES_PASSWORD is set in docker-compose.yml
